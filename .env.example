# ─────────────────────────────────────────────────────────────────
# ViralADN — Plantilla de variables de entorno
# Copiá este archivo a `.env.local` y completá cada valor.
# NUNCA subas .env.local a git.
# ─────────────────────────────────────────────────────────────────

# === APP ========================================================
# URL pública de tu deploy. En local dejá http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Si está en "1" se activa el gate de login en /app. Dejá en 1 en prod.
REQUIRE_AUTH=1

# Días de trial por default cuando alguien redime un código sin duración custom.
TRIAL_DAYS=5


# === SUPABASE ===================================================
# Crear proyecto en https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Service role: poder de admin (usar SOLO en server). Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx


# === STRIPE =====================================================
# https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook secret de https://dashboard.stripe.com/webhooks (después de crear endpoint)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs creados en Products. Mensual y anual.
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx


# === EMAIL (Resend) =============================================
# https://resend.com → API Keys
RESEND_API_KEY=re_xxx
# Sender. Tenés que verificar el dominio en Resend antes de mandar.
RESEND_FROM="ViralADN <hola@tudominio.com>"


# === OPENAI (generación de guiones + análisis de relevancia) ====
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# Alternativa más barata para hooks (opcional, no obligatorio).
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx


# === APIFY (scraping de TikTok / Instagram) =====================
# https://console.apify.com/settings/integrations
APIFY_TOKEN=apify_api_xxx


# === YOUTUBE (búsqueda y metadata) ==============================
# https://console.cloud.google.com → API & Services → Credentials
YOUTUBE_API_KEY=AIzaSy_xxx


# === SUPADATA (transcripción YouTube/IG/TikTok) =================
# https://supadata.ai
SUPADATA_API_KEY=sd_xxx


# === SEARCH (Serper / RapidAPI - opcionales) ====================
# https://serper.dev
SERPER_API_KEY=
# https://rapidapi.com
RAPIDAPI_KEY=


# === MEDIA STOCK (opcional) =====================================
# https://www.pexels.com/api/
PEXELS_API_KEY=


# === ADMIN PANEL ================================================
# Emails que pueden entrar a /admin (separados por coma).
# Estos son los "owners" — sin esto, nadie puede acceder al panel.
ADMIN_EMAILS=tu-email@gmail.com

# PIN numérico requerido cada vez que se entra a /admin desde afuera.
# Elegí algo de 4-8 dígitos.
ADMIN_PIN=1234


# === CÓDIGOS DE INVITACIÓN (opcional) ===========================
# Códigos que activan trial sin pasar por Stripe.
# Formato:  CODIGO  o  CODIGO:DURACION
#   DURACION: 15m (minutos) | 2h (horas) | 5d (días)
# Separados por coma. Ejemplo:
#   INVITE_CODES=BETA50,VIP:1h,EXPERT:5d,PRUEBA:15m
INVITE_CODES=


# === EXTRAS (opcional, no obligatorios) =========================
# Google Sheets webhook si usás export externo
EXMA_GS_URL=
EXMA_GS_SECRET=
